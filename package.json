{
  "name": "yandex-smart-home-desktop",
  "version": "1.1.11",
  "private": true,
  "description": "Windows desktop dashboard for Yandex Smart Home devices.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main/main.js && node --check src/main/preload.js && node --check src/renderer/app.js",
    "pack:win": "electron-builder --win --x64"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.yandex-smart-home.desktop",
    "productName": "Yandex Smart Home",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
